# Git LFS — track large binary artifacts
# PDFs (source scans): ~185MB total
*.pdf filter=lfs diff=lfs merge=lfs -text

# Images (page renders): ~1MB each, ~3K pages full run
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Embeddings / binary arrays
*.npy filter=lfs diff=lfs merge=lfs -text
*.f32 filter=lfs diff=lfs merge=lfs -text
*.npz filter=lfs diff=lfs merge=lfs -text

# Model weights (if ever committed)
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text

# Normalize text files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.jsonl text eol=lf
*.sh text eol=lf
*.toml text eol=lf
